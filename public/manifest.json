{
  "manifest_version": 3,
  "name": "Judol Detector",
  "version": "0.1.0",
  "description": "Chromium extension untuk mendeteksi konten judol.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "images/logo.png",
    "32":  "images/logo.png",
    "48":  "images/logo.png",
    "128": "images/logo.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "images/logo.png",
      "32":  "images/logo.png",
      "48":  "images/logo.png",
      "128": "images/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["keywords/keywords.txt"],
      "matches": ["<all_urls>"]
    }
  ]
}
