{
  "manifest_version": 3,
  "name": "Judol Detector",
  "version": "0.1.0",
  "description": "Chromium extension untuk mendeteksi konten judol.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
